// ============================================================
// A5X CRM — Prisma Schema (Phase 1)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  CEO
  CFO
  SALES_MANAGER
  SALES_EXECUTIVE
  MARKETING_MANAGER
  MARKETING_EXECUTIVE
  SUPPORT
  HR
}

enum LeadStatus {
  NEW_LEAD
  CONTACTED
  IN_DISCUSSION
  MEETING_SCHEDULED
  DEMO_SCHEDULED
  DEMO_COMPLETED
  PROPOSAL_SENT
  NEGOTIATION
  WAITING_APPROVAL
  CONFIRMED
  LOST
  FUTURE_OPPORTUNITY
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum FollowupType {
  CALL
  MEETING
  DEMO
  EMAIL
  WHATSAPP
  VISIT
}

enum FollowupStatus {
  PENDING
  DONE
  CANCELLED
}

enum ActivityType {
  NOTE
  STATUS_CHANGE
  FOLLOWUP
  TASK
  FILE_UPLOAD
  EMAIL_SENT
  CALL
  MEETING
}

// ─────────────────────────────────────────────
// USER (authentication + roles)
// ─────────────────────────────────────────────

model User {
  id             String    @id @default(uuid())
  name           String
  email          String    @unique
  password       String
  role           Role      @default(SALES_EXECUTIVE)
  avatar         String?
  phone          String?
  isActive       Boolean   @default(true)
  refreshToken   String?
  resetToken     String?
  resetTokenExp  DateTime?
  lastLogin      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  permissions    UserPermission[]
  leads          Lead[]           @relation("LeadAssignedTo")
  createdLeads   Lead[]           @relation("LeadCreatedBy")
  tasks          Task[]           @relation("TaskAssignedTo")
  createdTasks   Task[]           @relation("TaskCreatedBy")
  followups      Followup[]
  activities     Activity[]
  notifications  Notification[]
  uploadedFiles  File[]


  // Finance module relations
  expenses     Expense[]          @relation("SubmittedExpenses")
  payrolls     Payroll[]          @relation("EmployeePayrolls")
  financeDocs  FinanceDocument[]  @relation("UploadedDocs")
  @@map("users")
}

// ─────────────────────────────────────────────
// PERMISSIONS (dynamic, not hardcoded)
// ─────────────────────────────────────────────

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique   // e.g. "leads:create"
  description String?
  module      String           // e.g. "leads", "contacts", "tasks"
  action      String           // e.g. "create", "read", "update", "delete"
  createdAt   DateTime         @default(now())

  userPermissions UserPermission[]

  @@map("permissions")
}

model UserPermission {
  id           String     @id @default(uuid())
  userId       String
  permissionId String
  granted      Boolean    @default(true)
  createdAt    DateTime   @default(now())

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

// ─────────────────────────────────────────────
// CONTACT (person linked to a lead / company)
// ─────────────────────────────────────────────

model Contact {
  id            String    @id @default(uuid())
  firstName     String
  lastName      String
  email         String?
  mobile        String?
  whatsapp      String?
  designation   String?
  department    String?
  isPrimary     Boolean   @default(false)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  leadId        String?
  lead          Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  companyId     String?
  company       Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  activities    Activity[]


  quotations  Quotation[]
  invoices    Invoice[]
  @@map("contacts")
}


// ─────────────────────────────────────────────
// COMPANY
// ─────────────────────────────────────────────

model Company {
  id          String    @id @default(uuid())
  name        String
  website     String?
  industry    String?
  size        String?
  address     String?
  city        String?
  state       String?
  country     String?   @default("India")
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  contacts    Contact[]
  leads       Lead[]

  @@map("companies")
}

// ─────────────────────────────────────────────
// LEAD (core sales record)
// ─────────────────────────────────────────────

model Lead {
  id                 String       @id @default(uuid())
  leadNumber         String       @unique  // e.g. A5X-0001
  organization       String
  contactPerson      String
  designation        String?
  mobile             String
  whatsapp           String?
  email              String?
  website            String?
  address            String?
  city               String?
  state              String?
  country            String?      @default("India")
  industry           String?
  source             String?
  interestedService  String?
  boards             String?      // Educational boards like CBSE, ICSE, MP Board etc
  status             LeadStatus   @default(NEW_LEAD)
  priority           Priority     @default(MEDIUM)
  expectedValue      Float?       @default(0)
  probability        Int?         @default(0)
  expectedCloseDate  DateTime?
  proposalSent       Boolean      @default(false)
  demoDone           Boolean      @default(false)
  decisionMaker      Boolean      @default(false)
  lastContact        DateTime?
  nextFollowup       DateTime?
  remarks            String?
  tags               String[]     @default([])
  isActive           Boolean      @default(true)

  assignedToId       String?
  assignedTo         User?        @relation("LeadAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById        String?
  createdBy          User?        @relation("LeadCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  companyId          String?
  company            Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)

  contacts           Contact[]
  tasks              Task[]
  followups          Followup[]
  activities         Activity[]
  files              File[]

  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@map("leads")
}

// ─────────────────────────────────────────────
// TASK
// ─────────────────────────────────────────────

model Task {
  id            String      @id @default(uuid())
  title         String
  description   String?
  status        TaskStatus  @default(TODO)
  priority      Priority    @default(MEDIUM)
  dueDate       DateTime?
  completedAt   DateTime?
  reminder      DateTime?

  leadId        String?
  lead          Lead?       @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignedToId  String?
  assignedTo    User?       @relation("TaskAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById   String?
  createdBy     User?       @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  comments      TaskComment[]
  activities    Activity[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String?
  content   String
  createdAt DateTime @default(now())

  @@map("task_comments")
}

// ─────────────────────────────────────────────
// FOLLOWUP
// ─────────────────────────────────────────────

model Followup {
  id          String         @id @default(uuid())
  type        FollowupType
  status      FollowupStatus @default(PENDING)
  scheduledAt DateTime
  completedAt DateTime?
  notes       String?
  outcome     String?

  leadId      String?
  lead        Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  createdById String?
  createdBy   User?          @relation(fields: [createdById], references: [id], onDelete: SetNull)

  activities  Activity[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("followups")
}

// ─────────────────────────────────────────────
// ACTIVITY TIMELINE (universal audit log)
// ─────────────────────────────────────────────

model Activity {
  id          String       @id @default(uuid())
  type        ActivityType
  description String
  metadata    Json?        // flexible extra data

  leadId      String?
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contactId   String?
  contact     Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  taskId      String?
  task        Task?        @relation(fields: [taskId], references: [id], onDelete: SetNull)
  followupId  String?
  followup    Followup?    @relation(fields: [followupId], references: [id], onDelete: SetNull)
  userId      String?
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt   DateTime     @default(now())

  @@map("activities")
}

// ─────────────────────────────────────────────
// FILE
// ─────────────────────────────────────────────

model File {
  id           String   @id @default(uuid())
  originalName String
  storedName   String
  mimeType     String
  size         Int
  url          String
  leadId       String?
  lead         Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@map("files")
}

// ─────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   // "task_assigned" | "lead_assigned" | "followup_reminder" | "meeting_reminder"
  isRead    Boolean  @default(false)
  link      String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@map("notifications")
}

// ─────────────────────────────────────────────
// FINANCE MODULE (Phase 3)
// ─────────────────────────────────────────────

enum QuotationStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum PaymentMode {
  CASH
  UPI
  CARD
  NEFT
  RTGS
  CHEQUE
}

enum PaymentStatus {
  PAID
  PARTIAL
  OVERDUE
  REFUNDED
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ExpenseCategory {
  TRAVEL
  SALARY
  MARKETING
  HOSTING
  OFFICE_RENT
  ELECTRICITY
  EQUIPMENT
  FOOD
  MISC
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  APPROVED
  DELIVERED
  CANCELLED
}

enum GSTType {
  CGST_SGST
  IGST
  EXEMPT
}

enum DocumentType {
  INVOICE
  BILL
  CONTRACT
  SALARY_SLIP
  GST_FILE
  PURCHASE_ORDER
  OTHER
}

model FinanceSettings {
  id                  String   @id @default(uuid())
  companyName         String
  companyAddress      String?
  companyPhone        String?
  companyEmail        String?
  companyWebsite      String?
  companyLogo         String?
  gstin               String?
  pan                 String?
  currency            String   @default("INR")
  currencySymbol      String   @default("₹")
  financialYearStart  String   @default("04")
  invoicePrefix       String   @default("INV")
  quotationPrefix     String   @default("QT")
  purchaseOrderPrefix String   @default("PO")
  defaultTaxRate      Float    @default(18)
  gstType             GSTType  @default(CGST_SGST)
  cgstRate            Float    @default(9)
  sgstRate            Float    @default(9)
  igstRate            Float    @default(18)
  bankAccounts        Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("finance_settings")
}

model Quotation {
  id                 String          @id @default(uuid())
  quotationNumber    String          @unique
  title              String
  contactId          String
  contact            Contact         @relation(fields: [contactId], references: [id])
  issueDate          DateTime        @default(now())
  expiryDate         DateTime
  status             QuotationStatus @default(DRAFT)
  subtotal           Float
  discountType       String?
  discountValue      Float           @default(0)
  discountAmount     Float           @default(0)
  taxableAmount      Float
  gstType            GSTType         @default(CGST_SGST)
  cgstAmount         Float           @default(0)
  sgstAmount         Float           @default(0)
  igstAmount         Float           @default(0)
  taxAmount          Float           @default(0)
  grandTotal         Float
  notes              String?
  terms              String?
  convertedToInvoice Boolean         @default(false)
  invoiceId          String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  items QuotationItem[]

  @@map("quotations")
}

model QuotationItem {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  description String
  quantity    Float
  unitPrice   Float
  discountPct Float     @default(0)
  taxRate     Float     @default(0)
  amount      Float
  createdAt   DateTime  @default(now())

  @@map("quotation_items")
}

model Invoice {
  id             String        @id @default(uuid())
  invoiceNumber  String        @unique
  title          String?
  contactId      String
  contact        Contact       @relation(fields: [contactId], references: [id])
  quotationId    String?
  issueDate      DateTime      @default(now())
  dueDate        DateTime
  status         InvoiceStatus @default(DRAFT)
  subtotal       Float
  discountType   String?
  discountValue  Float         @default(0)
  discountAmount Float         @default(0)
  taxableAmount  Float
  gstType        GSTType       @default(CGST_SGST)
  cgstAmount     Float         @default(0)
  sgstAmount     Float         @default(0)
  igstAmount     Float         @default(0)
  taxAmount      Float         @default(0)
  grandTotal     Float
  amountPaid     Float         @default(0)
  balanceDue     Float
  notes          String?
  terms          String?
  qrCode         String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  items    InvoiceItem[]
  payments Payment[]

  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float
  unitPrice   Float
  discountPct Float    @default(0)
  taxRate     Float    @default(0)
  amount      Float
  createdAt   DateTime @default(now())

  @@map("invoice_items")
}

model Payment {
  id            String        @id @default(uuid())
  paymentNumber String        @unique
  invoiceId     String
  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
  amount        Float
  paymentDate   DateTime      @default(now())
  paymentMode   PaymentMode   @default(CASH)
  status        PaymentStatus @default(PAID)
  reference     String?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("payments")
}

model Expense {
  id            String          @id @default(uuid())
  title         String
  description   String?
  amount        Float
  category      ExpenseCategory @default(MISC)
  expenseDate   DateTime        @default(now())
  status        ExpenseStatus   @default(PENDING)
  billUrl       String?
  submittedById String
  submittedBy   User            @relation("SubmittedExpenses", fields: [submittedById], references: [id])
  approvedById  String?
  approvedAt    DateTime?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("expenses")
}

model Payroll {
  id              String    @id @default(uuid())
  employeeId      String
  employee        User      @relation("EmployeePayrolls", fields: [employeeId], references: [id])
  month           Int
  year            Int
  basicSalary     Float
  hra             Float     @default(0)
  allowances      Float     @default(0)
  commission      Float     @default(0)
  bonus           Float     @default(0)
  grossSalary     Float
  pf              Float     @default(0)
  esi             Float     @default(0)
  tds             Float     @default(0)
  otherDeductions Float     @default(0)
  totalDeductions Float
  netSalary       Float
  isPaid          Boolean   @default(false)
  paidAt          DateTime?
  slipUrl         String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([employeeId, month, year])
  @@map("payrolls")
}

model Vendor {
  id          String   @id @default(uuid())
  name        String
  email       String?
  phone       String?
  company     String?
  address     String?
  city        String?
  state       String?
  country     String?
  pincode     String?
  gstin       String?
  pan         String?
  bankName    String?
  bankAccount String?
  bankIfsc    String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@map("vendors")
}

model PurchaseOrder {
  id                String              @id @default(uuid())
  poNumber          String              @unique
  vendorId          String
  vendor            Vendor              @relation(fields: [vendorId], references: [id])
  issueDate         DateTime            @default(now())
  expectedDelivery  DateTime?
  status            PurchaseOrderStatus @default(DRAFT)
  subtotal          Float
  taxAmount         Float               @default(0)
  grandTotal        Float
  notes             String?
  invoiceAttachment String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  items PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  description     String
  quantity        Float
  unitPrice       Float
  taxRate         Float         @default(0)
  amount          Float
  createdAt       DateTime      @default(now())

  @@map("purchase_order_items")
}

model FinanceDocument {
  id           String       @id @default(uuid())
  title        String
  type         DocumentType @default(OTHER)
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  description  String?
  uploadedById String
  uploadedBy   User         @relation("UploadedDocs", fields: [uploadedById], references: [id])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("finance_documents")
}

model FinanceCounter {
  id        String   @id @default(uuid())
  name      String   @unique
  prefix    String
  current   Int      @default(0)
  year      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("finance_counters")
}
